# ---------------------------------------------------------------------------
# Environment — copy this file to .env for local development
# .env is gitignored and must never be committed
# ---------------------------------------------------------------------------

# Target environment name (local | staging | production)
ENV=local

# Zippopotam API base URL — override to point at a different environment
API_BASE_URL=https://api.zippopotam.us

# HTTP request timeout in seconds
API_TIMEOUT=10

# Maximum acceptable response time in milliseconds (performance tests)
PERFORMANCE_THRESHOLD_MS=3000
